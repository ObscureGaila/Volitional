{
    "aux_provider": {
        "description": "辅助模型",
        "type": "string",
        "hint": "选择一个用于辅助判断的大模型",
        "_special": "select_provider"
    },
    "multimodal_provider": {
        "description": "多模态辅助模型",
        "type": "string",
        "hint": "选择一个用于识别图片、视频、文字内容的多模态模型",
        "_special": "select_provider"
    },
    "bot_name": {
        "description": "机器人名字",
        "type": "string",
        "hint": "机器人在聊天中的名字，用于辅助模型识别自身。留空则使用机器人的ID。",
        "default": ""
    },
    "max_context_messages": {
        "description": "上下文消息数量",
        "type": "int",
        "hint": "发送给辅助模型的最近消息条数",
        "default": 5,
        "slider": {"min": 1, "max": 20, "step": 1}
    },
    "reply_threshold": {
        "description": "回复阈值",
        "type": "float",
        "hint": "综合得分需 >= 此值才建议回复",
        "default": 0.67,
        "slider": {"min": 0, "max": 1, "step": 0.05}
    },
    "weights": {
        "description": "指标权重（总和应为 1.0）",
        "type": "object",
        "hint": "调整各指标对综合得分的贡献比例",
        "items": {
            "speaker_target_clarity": {
                "description": "发言指向明确度权重",
                "type": "float",
                "hint": "消息是否明确指向机器人",
                "default": 0.15,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "privacy_safety_risk": {
                "description": "隐私安全风险权重",
                "type": "float",
                "hint": "消息是否涉及敏感/违规内容",
                "default": 0.05,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "relevance": {
                "description": "关联度权重",
                "type": "float",
                "hint": "消息与话题和机器人角色的双重关联程度",
                "default": 0.15,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "user_intent_clarity": {
                "description": "用户意图清晰度权重",
                "type": "float",
                "hint": "发言者的核心表达意图是否明确可识别",
                "default": 0.10,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "replyability": {
                "description": "可回复性权重",
                "type": "float",
                "hint": "消息中是否存在机器人可自然回应的内容点",
                "default": 0.15,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "context_completeness": {
                "description": "语境完整度权重",
                "type": "float",
                "hint": "结合历史上下文是否能完整理解消息",
                "default": 0.05,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "turn_idleness": {
                "description": "对话轮次空闲度权重",
                "type": "float",
                "hint": "当前对话轮次是否适合机器人介入",
                "default": 0.10,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "emotional_suitability": {
                "description": "情感适合度权重",
                "type": "float",
                "hint": "群聊整体情绪氛围是否适合介入",
                "default": 0.10,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "intervention_naturalness": {
                "description": "介入自然度权重",
                "type": "float",
                "hint": "此时介入是否符合群聊社交逻辑",
                "default": 0.10,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            },
            "group_atmosphere_fit": {
                "description": "群聊氛围适配度权重",
                "type": "float",
                "hint": "回复风格是否匹配群聊一贯调性",
                "default": 0.05,
                "slider": {"min": 0, "max": 1, "step": 0.05}
            }
        }
    },
    "cooldown_enabled": {
        "description": "启用回复冷却",
        "type": "bool",
        "hint": "开启后，机器人回复一次后会在一定时间内降低再次回复的概率",
        "default": true
    },
    "cooldown_seconds": {
        "description": "冷却时长（秒）",
        "type": "int",
        "hint": "回复后的冷却周期，在此期间扣分逐渐衰减至零",
        "default": 120,
        "slider": {"min": 5, "max": 3600, "step": 5}
    },
    "cooldown_deduction": {
        "description": "冷却扣分",
        "type": "float",
        "hint": "刚回复完时的最大扣分值，随时间线性衰减",
        "default": 0.20,
        "slider": {"min": 0, "max": 0.5, "step": 0.05}
    },
    "poll_interval": {
        "description": "主动获取最新消息间隔",
        "type": "int",
        "hint": "主动获取最新消息的间隔，单位：秒。设置为0时表示实时检查，将消耗大量token。",
        "default": 300,
        "slider": {"min": 0, "max": 86400, "step": 5}
    }
}
